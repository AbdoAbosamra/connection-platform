# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION environment for remotearena.io
# Copy to `.env` ON THE SERVER, fill the blanks, then run `php artisan key:generate`.
# NEVER commit the real .env — only this template.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=RemoteArena
APP_ENV=production
APP_KEY=                              # run: php artisan key:generate
APP_DEBUG=false                       # MUST stay false in production
APP_URL=https://remotearena.io

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error                       # quieter logs in prod

# ── Database (create these in CloudPanel → Databases) ───────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=remotearena
DB_USERNAME=remotearena
DB_PASSWORD=                          # strong unique password (NOT the dev one)

# ── Sessions / cache / queue ────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database             # use a worker (php artisan queue:work) in prod
FILESYSTEM_DISK=public

# ── Frontend origin (for CORS when called cross-origin) ─────────────────────
FRONTEND_URL=https://remotearena.io

# ── Mail (use a real SMTP provider — emails won't send with 'log') ──────────
MAIL_MAILER=smtp
MAIL_HOST=                            # e.g. smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="support@remotearena.io"
MAIL_FROM_NAME="${APP_NAME}"

# ── Observability ───────────────────────────────────────────────────────────
# Telescope writes to the DB on every request and exposes traffic/queries.
# Keep it OFF in production (admins can still enable temporarily if needed).
TELESCOPE_ENABLED=false

# ── Billing (optional — leave as mock until you wire real Stripe) ────────────
BILLING_DRIVER=mock
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Employer verification (optional) ────────────────────────────────────────
VERIFICATION_CHECK_MX=true           # confirm company domains can receive mail
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
