APP_NAME=RemoteArena
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=connextion
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Real-time: set to "reverb" and run `php artisan reverb:start` to enable live
# messaging/notifications; "null" (or "log") keeps the app on polling.
BROADCAST_CONNECTION=null
FILESYSTEM_DISK=public

# Laravel Reverb (WebSocket server). Populated by `php artisan reverb:install`.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_DATABASE_TABLE=cache
CACHE_DATABASE_CONNECTION=null

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@connextion.io"
MAIL_FROM_NAME="${APP_NAME}"

# Production: use ses, mailgun, postmark, etc.
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Billing: "mock" activates subscriptions instantly (default, no keys needed);
# "stripe" uses Stripe Checkout and requires the keys below.
BILLING_DRIVER=mock

# Stripe (for subscription payments — only needed when BILLING_DRIVER=stripe)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Employer verification
# check_mx confirms a company domain can actually receive mail (live DNS query).
VERIFICATION_CHECK_MX=false
VERIFICATION_PAYMENT_AMOUNT=100
# LinkedIn OAuth (leave empty to disable LinkedIn verification; payment still works)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI defaults to "${APP_URL}/api/auth/linkedin/callback"

# CORS (set to your frontend URL)
FRONTEND_URL=http://localhost:5173

# Not used — this API uses Bearer token auth, not cookie-based SPA sessions.
# SANCTUM_STATEFUL_DOMAINS=localhost:5173
